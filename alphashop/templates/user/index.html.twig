{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Liste des utilisateurs</h1>
        
        {% include 'layouts/_flash_message.html.twig' %}

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Rôles</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user.nom }}</td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.telephone }}</td>
                    <td>
                        {# badges de rôles #}
                        {% if "ROLE_ADMIN" in user.roles %}
                            <span class="badge bg-primary">Administrateur</span>
                        {% elseif "ROLE_EDITOR" in user.roles %}
                            <span class="badge bg-success">Éditeur</span>
                        {% else %}
                            <span class="badge bg-secondary">Client</span>
                        {% endif %}
                    </td>
                    <td>
                        
                        {% if 'ROLE_ADMIN' not in user.roles %}
                            
                            {# Gestion du rôle ÉDITEUR #}
                            {% if 'ROLE_EDITOR' not in user.roles %}
                                <a onclick="return confirm('Promouvoir cet utilisateur en éditeur ?')" href="{{ path('app_user_to_editor', {'id': user.id, 'role': 'ROLE_EDITOR'}) }}" class="btn btn-sm btn-outline-primary">Passer Éditeur</a>
                            {% else %}
                                <a onclick="return confirm('Retirer le rôle éditeur ?')" href="{{ path('app_user_remove_editor_role', {'id': user.id}) }}" class="btn btn-sm btn-outline-warning">Retirer Éditeur</a>
                            {% endif %}
                            {# Bouton Supprimer #}
                            <a onclick="return confirm('Voulez-vous vraiment supprimer cet utilisateur ?')" href="{{ path('app_user_delete', {'id': user.id}) }}" class="btn btn-sm btn-danger">Supprimer</a>
                        
                        {% else %}
                            <span class="text-muted small">Aucune action possible</span>
                        {% endif %}
                        
                        <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-sm btn-info text-white">Voir</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center">Aucun utilisateur trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-3">
            <a href="{{ path('app_user_new') }}" class="btn btn-primary">Créer un nouvel utilisateur</a>
        </div>
    </div>
{% endblock %}