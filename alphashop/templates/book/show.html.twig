{% extends 'base.html.twig' %}

{% block title %}Détails - {{ book.titre }}{% endblock %}

{% block body %}
<div class="container mt-5">
    {# Fil d'Ariane pour la navigation #}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Catalogue</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ book.titre }}</li>
        </ol>
    </nav>

    <div class="row mt-4">
        {# Colonne GAUCHE : L'image du livre #}
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                {% if book.image %}
                    <img src="{{ asset('/images/' ~ book.image) }}" class="img-fluid rounded-start" alt="{{ book.titre }}">
                {% else %}
                    <img src="https://via.placeholder.com/400x600?text=Pas+d'image" class="img-fluid rounded-start" alt="Image par défaut">
                {% endif %}
            </div>
        </div>

        {# Colonne DROITE : Informations et Actions #}
        <div class="col-md-8">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h1 class="card-title text-primary">{{ book.titre }}</h1>
                        <span class="badge {{ book.stock > 0 ? 'bg-success' : 'bg-danger' }} p-2">
                            {{ book.stock > 0 ? book.stock ~ ' en stock' : 'Épuisé' }}
                        </span>
                    </div>
                    
                    <h4 class="text-muted mb-4">par {{ book.auteur }}</h4>

                    <hr>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">ISBN :</div>
                        <div class="col-sm-9 text-secondary">{{ book.isbn }}</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-3 fw-bold">ID Référence :</div>
                        <div class="col-sm-9 text-secondary">#{{ book.id }}</div>
                    </div>

                    <div class="d-flex gap-2 mt-5">
                        <a href="{{ path('app_book_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Retour
                        </a>
                        
                        {# Actions spécifiques ADMIN #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-warning">
                                <i class="bi bi-pencil-square"></i> Modifier
                            </a>
                            <a href="{{ path('app_book_stock_add', {'id': book.id}) }}" class="btn btn-outline-info">
                                <i class="bi bi-plus-circle"></i> Stock
                            </a>
                            <div class="ms-auto">
                                {{ include('book/_delete_form.html.twig') }}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}