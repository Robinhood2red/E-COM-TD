{% extends 'base.html.twig' %}

{% block title %}Stock - {{ book.titre }}{% endblock %}

{% block body %}
<div class="container mt-5">
    {# Fil d'Ariane #}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Catalogue</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_book_show', {'id': book.id}) }}">{{ book.titre }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">Ajout de stock</li>
        </ol>
    </nav>

    {{ include ('layouts/_flash_message.html.twig') }} 

    <div class="row mt-4">
        {# Colonne GAUCHE : Rappel visuel du livre #}
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                {% if book.image %}
                    <img src="{{ asset('/images/' ~ book.image) }}" class="img-fluid rounded shadow-sm" alt="{{ book.titre }}">
                {% else %}
                    <img src="https://via.placeholder.com/400x600?text=Pas+d'image" class="img-fluid rounded shadow-sm" alt="Image par défaut">
                {% endif %}
                <div class="card-body text-center">
                    <h5 class="mb-1 text-truncate">{{ book.titre }}</h5>
                    <p class="text-muted small">par {{ book.auteur }}</p>
                </div>
            </div>
        </div>

        {# Colonne DROITE : Formulaire de stock #}
        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-info text-white py-3">
                    <h2 class="h4 mb-0"><i class="bi bi-box-seam"></i> Gestion du Stock</h2>
                </div>
                
                <div class="card-body p-4">
                    <div class="mb-4 text-center p-3 bg-light rounded">
                        <span class="text-uppercase small fw-bold text-muted d-block mb-1">Stock Actuel</span>
                        <h2 class="display-6 fw-bold {{ book.stock > 5 ? 'text-primary' : 'text-danger' }}">
                            {{ book.stock }} <small class="h6 text-muted">unités</small>
                        </h2>
                    </div>

                    <hr class="mb-4">

                    {{ form_start(form) }}
                        <div class="mb-4">
                            {{ form_label(form.quantity, 'Quantité à ajouter au stock', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.quantity, {
                                'attr':{
                                    'class':'form-control form-control-lg', 
                                    'placeholder': 'Entrez le nombre d\'exemplaires reçus...'
                                }
                            }) }}
                            {{ form_errors(form.quantity) }}
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">
                            <i class="bi bi-plus-circle"></i> Confirmer l'approvisionnement
                        </button>
                    {{ form_end(form) }}

                    <div class="mt-4 pt-3 border-top">
                        <a class="btn btn-link text-secondary p-0" href="{{ path('app_book_index') }}">
                            <i class="bi bi-arrow-left"></i> Annuler et retourner à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}