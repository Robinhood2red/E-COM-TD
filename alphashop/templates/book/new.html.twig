{% extends 'base.html.twig' %}

{% block title %}Nouveau Livre - AlphaShop{% endblock %}

{% block body %}
<div class="container mt-5 pb-5">
    {# Fil d'Ariane #}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Catalogue</a></li>
            <li class="breadcrumb-item active" aria-current="page">Ajouter un ouvrage</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                {# Header bleu (Primary) pour la création, différent du orange (Warning) de l'édition #}
                <div class="card-header bg-primary text-white py-3">
                    <h2 class="h4 mb-0"><i class="bi bi-plus-circle"></i> Ajouter un nouveau livre</h2>
                </div>
                
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Remplissez les informations ci-dessous pour intégrer un nouvel ouvrage au catalogue Alpha α.
                    </p>

                    <hr class="mb-4">

                    {# Inclusion du formulaire (BookType) #}
                    {# On passe 'Sauvegarder le livre' comme label pour le bouton #}
                    {{ include('book/_form.html.twig', {'button_label': 'Créer le livre'}) }}

                    <div class="mt-4 pt-3 border-top">
                        <a class="btn btn-link text-secondary p-0" href="{{ path('app_book_index') }}">
                            <i class="bi bi-arrow-left"></i> Annuler et revenir au catalogue
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}