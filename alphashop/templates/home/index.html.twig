{% extends 'base.html.twig' %}

{% block title %}Accueil - AlphaShop{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-5 text-center fw-bold">Nos Livres</h1>
    <div class="row g-4">
        {% for product in products %}
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 custom-card border-0 shadow-sm position-relative">
                    <div class="img-container">
                        {# Utilisation d'un placeholder car le champ image n'existe pas encore #}
                        <img src="{{ asset('/images/' ~ product.image) }}" class="card-img-top img-fluid" alt="{{ product.titre }}">
                        <div class="card-overlay">
                            <span class="badge bg-light text-dark shadow-sm">Certifié Alpha α</span>
                        </div>
                    </div>
                    
                    <div class="card-body d-flex flex-column text-center">
                        <a href="{{ path('app_home_product_show', {'id': product.id}) }}" class="stretched-link text-decoration-none text-dark">
                            <h2 class="card-title h5 fw-bold mb-3">{{ product.titre }}</h2>
                        </a>

                        <p class="card-text small mb-4 text-muted">
                            Auteur : {{ product.auteur|default('Anonyme') }}<br>
                            <span class="badge bg-secondary">ISBN: {{ product.isbn }}</span>
                        </p>
      
                        <div class="mt-auto" style="position: relative; z-index: 2;">
                            <a href="#" class="btn btn-outline-success w-100 shadow-sm">Détails</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <p class="text-center">Aucun livre disponible pour le moment.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}