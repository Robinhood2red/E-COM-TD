{% extends 'base.html.twig' %}

{% block title %}📚 Catalogue des Livres{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1>📚 Catalogue des Livres</h1>
        {# CRITÈRE : Seul l'Admin voit le bouton de création #}
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_book_new') }}" class="btn btn-primary">➕ Ajouter un livre</a>
        {% endif %}
    </div>

    <table class="table table-striped mt-4">
        <thead class="thead-dark">
            <tr>
                <th>Titre</th>
                <th>Auteur</th>
                <th>ISBN</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                <td>{{ book.titre }}</td>
                <td>{{ book.auteur }}</td>
                <td>{{ book.isbn }}</td>
                
                <td>
                    {% if book.stock > 0 %}
                        <span class="badge badge-success" style="background-color: green; color: white; padding: 5px;">
                            {{ book.stock }} en stock
                        </span>
                    {% else %}
                        <span class="badge badge-danger" style="background-color: red; color: white; padding: 5px;">
                            Épuisé
                        </span>
                    {% endif %}
                </td>

                <td>
                    {# ACCÈS USER : On peut emprunter si stock > 0 #}
                    {% if book.stock > 0 %}
                        <a href="{{ path('app_emprunt_new', {'id': book.id}) }}" class="btn btn-sm btn-outline-success">EMPRUNTER</a>
                    {% endif %}
                    
                    <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-sm btn-info">Détail</a>
                    
                    {# ACCÈS ADMIN : Seul l'admin voit le bouton Modifier #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center">Aucun livre dans le catalogue.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}