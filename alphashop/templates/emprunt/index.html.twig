{% extends 'base.html.twig' %}

{% block title %}{{ titre_page }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>{{ titre_page }}</h1>

    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Livre</th>
                <th>Emprunteur</th>
                <th>Date d'emprunt</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
        {% for emprunt in emprunts %}
            <tr>
                {# On accède au titre via la relation : emprunt -> book -> titre #}
                <td>{{ emprunt.book.titre }}</td>
                <td>{{ emprunt.user ? emprunt.user.nom : 'Utilisateur inconnu' }}</td>
                <td>{{ emprunt.dateEmprunt|date('d/m/Y H:i') }}</td>
                <td>
                    {% if emprunt.dateRetour is null %}
                        <span class="badge" style="background-color: #ffc107;">EN COURS</span>
                    {% else %}
                        <span class="badge" style="background-color: #28a745; color: white;">RENDU</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center">Aucun emprunt trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Retour au catalogue</a>
</div>
{% endblock %}