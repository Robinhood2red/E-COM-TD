{% extends 'base.html.twig' %}

{% block title %}{{ product.titre }}{% endblock %}

{% block body %}
<div class="container py-5">
    {# Bouton retour #}
    <div class="mb-4">
        <a href="{{ path('app_home_page') }}" class="btn btn-link text-decoration-none text-muted p-0">
            <i class="bi bi-arrow-left"></i> ← Retour au catalogue
        </a>
    </div>

    <div class="row g-5">
        {# Colonne Image #}
        <div class="col-md-6">
            <div class="product-image-container bg-light shadow-sm rounded-4 overflow-hidden text-center">
                {# On utilise un placeholder basé sur le titre car le champ image n'existe pas dans l'entité Book #}
                <img src="{{ asset('/images/' ~ product.image) }}" class="card-img-top img-fluid" alt="{{ product.titre }}">
            </div>
        </div>

        {# Colonne Infos #}
        <div class="col-md-6">
            <div class="ps-lg-4">
                <nav aria-label="breadcrumb" class="mb-2">
                    <span class="badge bg-success text-white mb-2">Certifié Alpha α</span>
                </nav>
                
                <h1 class="display-5 fw-bold mb-3">{{ product.titre }}</h1>
                
                {# Auteur au lieu du prix car 'price' n'existe pas #}
                <div class="h3 fw-light text-success mb-4">
                    Par : {{ product.auteur|default('Auteur inconnu') }}
                </div>

                <hr class="my-4 text-muted opacity-25">

                {# Détails techniques au lieu de la description inexistante #}
                <h5 class="fw-bold">Informations sur l'ouvrage</h5>
                <p class="leading-relaxed text-muted">
                    <strong>ISBN :</strong> {{ product.isbn }}<br>
                    <strong>Disponibilité :</strong> 
                    {% if product.stock > 0 %}
                        <span class="text-success">En stock ({{ product.stock }} exemplaires)</span>
                    {% else %}
                        <span class="text-danger">Indisponible</span>
                    {% endif %}
                </p>

                {# Btn Emprunter (plus logique pour un livre) #}
                <div class="d-grid gap-2 d-md-flex mt-5">
                    {% if product.stock > 0 %}
                        {# On transforme le <button> en <a> et on utilise 'product.id' #}
                        <a href="{{ path('app_emprunt_new', {'id': product.id}) }}" 
                        class="btn btn-success btn-lg px-5 py-3 shadow-sm rounded-pill">
                        Emprunter ce livre
                        </a>
                    {% else %}
                        {# Si pas de stock, on affiche un bouton grisé #}
                        <button class="btn btn-secondary btn-lg px-5 py-3 shadow-sm rounded-pill" disabled>
                        Victime de son succès (Épuisé)
                        </button>
                    {% endif %}

                    <button class="btn btn-outline-danger btn-lg px-4 py-3 rounded-pill">
                        <i class="bi bi-heart-fill"></i>
                    </button>
                </div>
                
                {# Texte livraison / service #}
                <div class="mt-4 pt-3 border-top">
                    <p class="small text-muted mb-0">
                        <i class="bi bi-info-circle"></i> Retrait disponible en bibliothèque sous 24h.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}